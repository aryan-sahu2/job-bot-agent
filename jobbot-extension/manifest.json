{
  "manifest_version": 3,
  "name": "JobBot Assistant",
  "version": "1.0",
  "description": "Auto-fill job apps via local Ollama",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["http://localhost:8765/*", "https://*/*", "http://*/*"],
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}