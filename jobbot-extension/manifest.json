{
  "manifest_version": 3,
  "name": "JobBot Assistant",
  "version": "1.0.0",
  "description": "Auto-fill job apps and generate cover letters via your local Ollama server",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}